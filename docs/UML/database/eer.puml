@startuml eer.puml
title DVLD System - Enhanced ER Diagram

entity Person {
  * PersonID : int
  --
  NationalNumber : string
  FullName : string
  DateOfBirth : date
}

entity User {
  * UserID : int
  --
  Username : string
  Password : string
}

entity Driver {
  * DriverID : int
}

entity License {
  * LicenseID : int
  --
  LicenseNumber : string
  ExpiryDate : date
}

entity InternationalLicense {
  * InternationalLicenseID : int
}

entity DetainedLicense {
  * DetentionID : int
  --
  FineAmount : decimal
}

entity Application {
  * ApplicationID : int
}

entity TestAppointment {
  * AppointmentID : int
}

entity TestResult {
  * TestResultID : int
  --
  Result : string
}

entity AuditLog {
  * AuditID : int
}

Person ||--o| User
Person ||--o| Driver
Person ||--o{ Application
Driver ||--o{ License
Driver ||--o{ InternationalLicense
License ||--o{ DetainedLicense
Application ||--o{ TestAppointment
TestAppointment ||--o| TestResult
User ||--o{ AuditLog

@enduml