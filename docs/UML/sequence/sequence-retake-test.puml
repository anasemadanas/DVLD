@startuml sequence-retake-test
title Retake Test Service - Sequence Diagram

actor "Licensing Employee" as Employee
boundary "DVLD UI" as UI
control "TestService" as TestService
control "ApplicationService" as AppService
database "SQL Server Database" as DB

Employee -> UI : Enter previous test number
UI -> TestService : Request retake test
TestService -> DB : Check previous test result
DB --> TestService : Failed / Passed result

alt Previous test failed
  TestService -> AppService : Create retake application
  AppService -> DB : Save new application linked to original
  DB --> AppService : Application saved
  TestService -> DB : Schedule new appointment
  DB --> TestService : Appointment saved
  TestService --> UI : Display appointment confirmation
else Previous test not failed
  TestService --> UI : Retake not allowed
end

@enduml
