@startuml sequence-first-time-license-issuance.puml
title First-Time License Issuance - Sequence Diagram

actor "Licensing Employee" as Employee
boundary "DVLD UI" as UI
control "LicenseService" as LicenseService
control "ValidationService" as ValidationService
control "TestService" as TestService
control "Data Access Layer" as DAL
database "SQL Server Database" as DB

Employee -> UI : Submit license application
UI -> LicenseService : Send application data
LicenseService -> ValidationService : Validate applicant eligibility
ValidationService -> DAL : Check age, license class, duplicates
DAL -> DB : Query applicant records
DB --> DAL : Applicant data
DAL --> ValidationService : Validation data

alt Applicant eligible
  LicenseService -> TestService : Verify required tests
  TestService -> DAL : Check vision, written, practical results
  DAL -> DB : Query test results
  DB --> DAL : Test results
  DAL --> TestService : Test status

  alt All tests passed
    LicenseService -> DAL : Create driving license
    DAL -> DB : Insert license record
    DB --> DAL : License saved
    DAL --> LicenseService : License data
    LicenseService --> UI : License issued successfully
  else Tests not completed
    LicenseService --> UI : Display tests required message
  end

else Applicant not eligible
  LicenseService --> UI : Display validation error
end

@enduml